# Precompro credentials.
# Sandbox/staging uses *.precompro.co. Production uses *.precompro.com.
PRECOMPRO_API_KEY=
PRECOMPRO_VENDOR_ID=

# Local server.
PORT=3000
# Required before exposing the middleware to agents/public URLs.
TOOL_SECRET=

# Base URLs.
# The public docs show staging hosts with a "2" suffix, but Ritwal tests currently
# respond on the hosts without "2". Keep these configurable per environment.
PRECOMPRO_RESERVATION_BASE=https://servicereservation2.precompro.co/api/ws
PRECOMPRO_AVAILABILITY_BASE=https://serviceavailability2.precompro.co/api
PRECOMPRO_VENDOR_BASE=https://servicevendor2.precompro.co/api
PRECOMPRO_WEBSERVICE_BASE=https://servicewebservice2.precompro.co/api

# Read-only test inputs.
TEST_DATE=
TEST_PEOPLE=2
TEST_ZONE=0
TEST_SUBZONE=0
TEST_PHONE=
TEST_INTUIPOS_ID=

# Write tests are disabled unless this is exactly true.
RUN_WRITE_TESTS=false

# Refresh rotates the Precompro apiKey. Keep disabled unless intentional.
RUN_REFRESH_TESTS=false
TEST_DISPLAY_NAME=Ritwal Sandbox
TEST_EMAIL=
TEST_PHONE_CREATE=
TEST_INDICATIVE=57
TEST_COMMENTS=Prueba automatizada desde sandbox Solvers AI
TEST_RESERVATION_EPOCH_MS=
TEST_BALANCE_PAID=
TEST_RESERVATION_ID=
CANCEL_AFTER_CREATE=true

# Middleware safety defaults.
DEFAULT_COUNTRY_CODE=57
MAX_AUTOMATIC_PARTY_SIZE=18
PRECOMPRO_TIMEOUT_MS=8000
IDEMPOTENCY_TTL_MS=600000
LOCK_TTL_MS=15000

PUBLIC_MIDDLEWARE_URL=https://ritwal-precompro-api.grupomistico.cloud

# Meta / WhatsApp Cloud API.
META_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Dokploy deploy automation.
DOKPLOY_BASE_URL=https://grupomistico.cloud/api
DOKPLOY_API_KEY=
DOKPLOY_APPLICATION_ID=
